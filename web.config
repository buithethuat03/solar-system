<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS config for the 3D Solar System (static site).
  Guarantees ES modules load (correct JavaScript MIME type) and that the site
  root serves index.html. Just drop this file in the site folder alongside index.html.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <!-- remove inherited mapping first, then set the correct one (avoids duplicate errors) -->
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="application/javascript" />
      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
